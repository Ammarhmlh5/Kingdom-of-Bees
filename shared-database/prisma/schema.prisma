ault(0) @map("honey_percentage")  pollenPercentage Int        @default(0) @map("pollen_percentage")  // Condition  condition FrameCondition @default(GOOD)  ageYears  Int            @default(0) @map("age_years")  // Tracking  lastUpdated DateTime @default(now()) @map("last_updated") @db.Timestamptz  updatedBy   String?  @map("updated_by") @db.Uuid  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  hive              Hive                    @relation(fields: [hiveId], references: [id], onDelete: Cascade)  inspectionDetails InspectionFrameDetail[]  @@unique([hiveId, story, position])  @@index([hiveId])  @@map("hive_frame")}model HiveSuper {  id     String @id @default(uuid()) @db.Uuid  hiveId String @map("hive_id") @db.Uuid  // Information  superNumber Int @map("super_number") // 1, 2, 3...  frameCount  Int @default(10) @map("frame_count")  // Settings  queenExcluder Boolean        @default(false) @map("queen_excluder")  queenLocation QueenLocation? @map("queen_location")  // Dates  addedDate   DateTime  @map("added_date") @db.Date  removedDate DateTime? @map("removed_date") @db.Date  // Production  estimatedYieldKg Decimal? @map("estimated_yield_kg") @db.Decimal(10, 2)  actualYieldKg    Decimal? @map("actual_yield_kg") @db.Decimal(10, 2)  // Status  status SuperStatus @default(ACTIVE)  // Tracking  addedBy   String?  @map("added_by") @db.Uuid  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  notes String?  // Relations  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)  @@index([hiveId])  @@map("hive_super")}model HiveHistory {  id     String @id @default(uuid()) @db.Uuid  hiveId String @map("hive_id") @db.Uuid  // Event  eventType HiveEventType @map("event_type")  // Details  description String  data        Json?  // Tracking  performedBy String?  @map("performed_by") @db.Uuid  performedAt DateTime @default(now()) @map("pe