pectionDate  DateTime @map("inspection_date") @db.Timestamptz  durationMinutes Int?     @map("duration_minutes")  // Type  inspectionType InspectionType @map("inspection_type")  // Weather  weatherConditions  String?  @map("weather_conditions")  temperatureCelsius Decimal? @map("temperature_celsius") @db.Decimal(5, 2)  // Overall Assessment  overallAssessment OverallAssessment @map("overall_assessment")  overallScore      Int?              @map("overall_score")  // Strength  strengthBefore Int? @map("strength_before")  strengthAfter  Int? @map("strength_after")  // Queen  queenSeen    Boolean?      @map("queen_seen")  queenQuality QueenQuality? @map("queen_quality")  eggsPresent  Boolean?      @map("eggs_present")  eggsPattern  EggPattern?   @map("eggs_pattern")  // Brood  broodPresent      Boolean?      @map("brood_present")  broodPattern      BroodPattern? @map("brood_pattern")  broodFramesCount  Int?          @map("brood_frames_count")  cappedBroodFrames Int?          @map("capped_brood_frames")  // Resources  honeyFramesCount  Int?     @map("honey_frames_count")  pollenFramesCount Int?     @map("pollen_frames_count")  estimatedHoneyKg  Decimal? @map("estimated_honey_kg") @db.Decimal(10, 2)  // Population  populationEstimate PopulationEstimate? @map("population_estimate")  framesCovered      Int?                @map("frames_covered")  // Temperament  temperament Temperament?  // Diseases & Pests  diseasesDetected Boolean @default(false) @map("diseases_detected")  pestsDetected    Boolean @default(false) @map("pests_detected")  // Swarm Signs  swarmCellsPresent Boolean    @default(false) @map("swarm_cells_present")  swarmCellsCount   Int        @default(0) @map("swarm_cells_count")  swarmRisk         SwarmRisk? @map("swarm_risk")  // Notes  notes           String?  recommendations String[]  // Media  images String[]  videos String[]  // Tracking  inspectedBy String?  @map("inspected_by") @db.Uuid  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  hive         Hive                    @relation(fields: [hiveId], references: [id], onDelete: Cascade)  apiary       Apiary                  @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  inspector    UserProfile?            @relation(fields: [inspectedBy], references: [id])  findings     InspectionFinding[]  actions      InspectionAction[]  frameDetails InspectionFrameDetail[]  @@index([hiveId, inspectionDate(sort: Desc)])  @@index([apiaryId, inspectionDate(sort: Desc)])  @@index([diseasesDetected])  @@map("inspection")}model InspectionFinding {  id           String @id @default(uuid()) @db.Uuid  inspectionId String @map("inspection_id") @db.Uuid  // Finding  findingType FindingType @map("finding_type")  severity    Severity  title       String  description String?  // Data  data Json?  // Recommended Action  recommendedAction String?         @map("recommended_action")  actionPriority    ActionPriority? @map("action_priority")  actionDeadline    DateTime?       @map("action_deadline") @db.Date  // Media  images String[]  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)  @@index([inspectionId])  @@map("inspection_finding")}model InspectionAction {  id           String @id @default(uuid()) @db.Uuid  inspectionId String @map("inspection_id") @db.Uuid  // Action  actionType  ActionType @map("action_type")  description String  // Details  details Json?  // Outcome  outcome String?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)  @@index([inspectionId])  @@map("inspection_action")}model InspectionFrameDetail {  id           String @id @default(uuid()) @db.Uuid  inspectionId String @map("inspection_id") @db.Uuid  frameId      String @map("frame_id") @db.Uuid  // State at inspection  position Int  broodPercentage Int?       @map("brood_percentage")  broodType       BroodType? @map("brood_type")  broodAge        BroodAge?  @map("brood_age")  honeyPercentage       Int? @map("honey_percentage")  honeyCappedPercentage Int? @map("honey_capped_percentage")  pollenPercentage Int?     @map("pollen_percentage")  pollenColors     String[] @map("pollen_colors")  // Notes  condition String?  notes     String?  // Media  imageUrl String? @map("image_url")  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)  frame      HiveFrame  @relation(fields: [frameId], references: [id], onDelete: Cascade)  @@index([inspectionId])  @@map("inspection_frame_detail")}// ============================================================================// ENUMS// ============================================================================// Inspection Enumsenum InspectionType {  ROUTINE  DETAILED  QUICK_CHECK  DISEASE_CHECK  QUEEN_CHECK  HARVEST  FEEDING  TREATMENT  OTHER  @@map("inspection_type")}enum OverallAssessment {  EXCELLENT  GOOD  FAIR  POOR  CRITICAL  @@map("overall_assessment")}enum QueenQuality {  EXCELLENT  GOOD  FAIR  POOR  ABSENT  @@map("queen_quality")}enum EggPattern {  EXCELLENT  GOOD  SPOTTY  POOR  NONE  @@map("egg_pattern")}enum BroodPattern {  EXCELLENT  GOOD  SPOTTY  POOR  NONE  @@map("brood_pattern")}enum PopulationEstimate {  VERY_STRONG  STRONG  MEDIUM  WEAK  VERY_WEAK  @@map("population_estimate")}enum Temperament {  VERY_GENTLE  GENTLE  NORMAL  DEFENSIVE  AGGRESSIVE  @@map("temperament")}enum SwarmRisk {  IMMINENT  HIGH  MODERATE  LOW  NONE  @@map("swarm_risk")}enum FindingType {  DISEASE  PEST  QUEEN_ISSUE  RESOURCE_SHORTAGE  CONGESTION  WEAK_POPULATION  AGGRESSIVE_BEHAVIOR  EXCELLENT_CONDITION  OTHER  @@map("finding_type")}enum Severity {  CRITICAL  HIGH  MEDIUM  LOW  INFO  @@map("severity")}enum ActionPriority {  IMMEDIATE  URGENT  SOON  ROUTINE  @@map("action_priority")}enum ActionType {  ADDED_FRAMES  REMOVED_FRAMES  ADDED_SUPER  REMOVED_SUPER  FED  TREATED  ADDED_QUEEN  REMOVED_QUEEN  HARVESTED  MOVED_FRAMES  SPLIT  MERGED  DESTROYED_QUEEN_CELLS  ADDED_FOUNDATION  COMPRESSED  OTHER  @@map("action_type")}enum BroodAge {  EGGS  YOUNG_LARVAE  OLD_LARVAE  CAPPED  MIXED  @@map("brood_age")}// User & Core Enumsenum UserType {  ADMIN  EXPLORER  OWNER  WORKER  @@map("user_type")}enum SubscriptionStatus {  FREE  ACTIVE  EXPIRED  CANCELLED  @@map("subscription_status")}enum SubscriptionPlan {  MONTHLY  YEARLY  @@map("subscription_plan")}enum MemberRole {  OWNER  WORKER  VIEWER  @@map("member_role")}enum MembershipStatus {  PENDING  ACTIVE  SUSPENDED  REMOVED  @@map("membership_status")}enum NotificationType {  INFO  WARNING  CRITICAL  REMINDER  ALERT  @@map("notification_type")}enum ApiaryType {  STATIONARY  MIGRATORY  @@map("apiary_type")}enum EquipmentAction {  ADDED  REMOVED  MAINTENANCE  REPAIR  DISPOSED  @@map("equipment_action")}model HiveType {  id          String  @id @default(uuid()) @db.Uuid  nameAr      String  @map("name_ar")  nameEn      String  @map("name_en")  description String?  // Specs  defaultFrames Int     @default(10) @map("default_frames")  dimensions    String? // e.g. "50x40x30 cm"  // Media  imageUrl String? @map("image_url")  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  hives     Hive[]  templates HiveTemplate[]  @@map("hive_type")}// Bee Genetics Catalog (Yemeni, Egyptian, etc.)model BeeBreed {  id          String  @id @default(uuid()) @db.Uuid  nameAr      String  @map("name_ar")  nameEn      String  @map("name_en")  description String?  // Characteristics (Analysis Data)  origin           String?  aggressionLevel  String? @map("aggression_level") // e.g., "High", "Low"  hardiness        String? // Disease resistance/Tolerance  productivity     String? // Honey production potential  winteringAbility String? @map("wintering_ability")  // Advanced Characteristics  characteristics Json @default("{}") // For dynamic future expansion  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  hives  Hive[]  queens Queen[]  @@map("bee_breed")}enum HiveStatus {  ACTIVE  QUEENLESS  WEAK  STRONG  SPLITTING  MERGED  DEAD  SOLD  @@map("hive_status")}enum StrengthRating {  VERY_STRONG  STRONG  MEDIUM  WEAK  VERY_WEAK  CRITICAL  @@map("strength_rating")}enum FrameType {  STANDARD  FOUNDATION  DRAWN  EMPTY  @@map("frame_type")}enum BroodType {  EGGS  LARVAE  CAPPED  MIXED  NONE  @@map("brood_type")}enum FrameCondition {  EXCELLENT  GOOD  FAIR  POOR  DAMAGED  @@map("frame_condition")}enum QueenLocation {  LOWER  UPPER  UNKNOWN  @@map("queen_location")}enum SuperStatus {  ACTIVE  FILLING  READY  HARVESTED  REMOVED  @@map("super_status")}enum HiveEventType {  CREATED  SPLIT  MERGED  REQUEENED  MOVED  STRENGTH_CHANGE  DISEASE_DETECTED  DISEASE_TREATED  HARVESTED  FED  SUPER_ADDED  SUPER_REMOVED  INSPECTION  STATUS_CHANGE  OTHER  @@map("hive_event_type")}enum FlightActivity {  VERY_HIGH  HIGH  MODERATE  LOW  VERY_LOW  NONE  @@map("flight_activity")}enum CombBuildingRate {  RAPID  GOOD  MODERATE  SLOW  NONE  @@map("comb_building_rate")}enum PollenCollectionRate {  ABUNDANT  GOOD  MODERATE  LOW  NONE  @@map("pollen_collection_rate")}// ============================================================================// E. QUEENS & NUCLEI (Basic for MVP - 2 tables)// ============================================================================model Queen {  id String @id @default(uuid()) @db.Uuid  // Basic Information  queenNumber String? @map("queen_number")  name        String?  // Source  source QueenSource  // Genetics  beeBreedId String?   @map("bee_breed_id") @db.Uuid  beeBreed   BeeBreed? @relation(fields: [beeBreedId], references: [id])  breederApiaryId String? @map("breeder_apiary_id") @db.Uuid  motherQueenId   String? @map("mother_queen_id") @db.Uuid  // Dates  birthDate        DateTime? @map("birth_date") @db.Date  introductionDate DateTime? @map("introduction_date") @db.Date  deathDate        DateTime? @map("death_date") @db.Date  // Marking  marked     Boolean @default(false)  markColor  String? @map("mark_color")  markNumber String? @map("mark_number")  // Quality  qualityRating Int?           @map("quality_rating")  eggLayingRate EggLayingRate? @map("egg_laying_rate")  temperament   Temperament?  // Performance  productivityScore      Int? @map("productivity_score")  diseaseResistanceScore Int? @map("disease_resistance_score")  // Genetics  geneticsData Json? @map("genetics_data")  // Status  status           QueenStatus @default(ACTIVE) @map("status")  currentHiveId    String?     @map("current_hive_id") @db.Uuid  currentNucleusId String?     @map("current_nucleus_id") @db.Uuid  // Statistics  offspringCount Int @default(0) @map("offspring_count")  hivesQueened   Int @default(0) @map("hives_queened")  // Notes  notes String?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  motherQueen    Queen?       @relation("QueenLineage", fields: [motherQueenId], references: [id])  daughters      Queen[]      @relation("QueenLineage")  currentHive    Hive?  currentNucleus Nucleus?     @relation(fields: [currentNucleusId], references: [id])  nuclei         Nucleus[]    @relation("NucleusQueen")  breederUser    UserProfile? @relation("QueenBreeder", fields: [breederApiaryId], references: [id])  @@index([status])  @@index([currentHiveId])  @@index([motherQueenId])  @@map("queen")}model Nucleus {  id       String @id @default(uuid()) @db.Uuid  apiaryId String @map("apiary_id") @db.Uuid  // Information  nucleusNumber String  @map("nucleus_number")  name          String?  // Configuration  frameCount Int @default(3) @map("frame_count")  // Queen  queenId               String?             @map("queen_id") @db.Uuid  queenIntroductionDate DateTime?           @map("queen_introduction_date") @db.Date  queenStatus           NucleusQueenStatus? @map("queen_status")  // Strength  strengthScore      Int?    @map("strength_score")  populationEstimate String? @map("population_estimate")  // Purpose  purpose NucleusPurpose  // Dates  createdDate    DateTime  @map("created_date") @db.Date  graduationDate DateTime? @map("graduation_date") @db.Date  // Status  status NucleusStatus @default(ACTIVE)  // Notes  notes String?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  apiary       Apiary  @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  queen        Queen?  @relation("NucleusQueen", fields: [queenId], references: [id])  queensHoused Queen[] @relation(fields: [], references: [])  @@index([apiaryId])  @@index([queenId])  @@map("nucleus")}// ============================================================================// F. FEEDING (3 tables)// ============================================================================model FeedingRecord {  id       String @id @default(uuid()) @db.Uuid  apiaryId String @map("apiary_id") @db.Uuid  hiveId   String @map("hive_id") @db.Uuid  // Date  feedingDate DateTime @map("feeding_date") @db.Timestamptz  // Type & Location  feedingLocation FeedingLocation @map("feeding_location")  feedingMethod   FeedingMethod?  @map("feeding_method")  // Content  contentType        FeedingContentType @map("content_type")  sugarConcentration String?            @map("sugar_concentration")  quantityKg         Decimal?           @map("quantity_kg") @db.Decimal(10, 2)  quantityLiters     Decimal?           @map("quantity_liters") @db.Decimal(10, 2)  // Purpose  purpose FeedingPurpose  // Consumption  consumedCompletely Boolean?  @map("consumed_completely")  consumptionDate    DateTime? @map("consumption_date") @db.Timestamptz  remainingAmount    Decimal?  @map("remaining_amount") @db.Decimal(10, 2)  // Honey Quality Impact  honeyQualityImpact   HoneyQualityImpact @default(NONE) @map("honey_quality_impact")  daysUntilSafeHarvest Int?               @map("days_until_safe_harvest")  // Side Effects  sideEffects String[] @map("side_effects")  // Cost  cost Decimal? @db.Decimal(10, 2)  // Notes  notes String?  // Tracking  fedBy     String?  @map("fed_by") @db.Uuid  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  apiary Apiary       @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  hive   Hive         @relation(fields: [hiveId], references: [id], onDelete: Cascade)  feeder UserProfile? @relation(fields: [fedBy], references: [id])  @@index([apiaryId, feedingDate(sort: Desc)])  @@index([hiveId, feedingDate(sort: Desc)])  @@index([honeyQualityImpact])  @@map("feeding_record")}model FeedingRecommendation {  id       String  @id @default(uuid()) @db.Uuid  apiaryId String  @map("apiary_id") @db.Uuid  hiveId   String? @map("hive_id") @db.Uuid  // Recommendation  recommendationDate DateTime       @default(now()) @map("recommendation_date") @db.Timestamptz  priority           ActionPriority  urgency            FeedingUrgency  // Feeding Details  recommendedType         String    @map("recommended_type")  recommendedLocation     String    @map("recommended_location")  recommendedQuantity     Decimal   @map("recommended_quantity") @db.Decimal(10, 2)  recommendedStartDate    DateTime? @map("recommended_start_date") @db.Date  recommendedDurationDays Int?      @map("recommended_duration_days")  // Reasoning  reasoning String  factors   Json?  // Expectations  expectedBenefits String[] @map("expected_benefits")  expectedRisks    String[] @map("expected_risks")  estimatedCost    Decimal? @map("estimated_cost") @db.Decimal(10, 2)  expectedRoi      Decimal? @map("expected_roi") @db.Decimal(10, 2)  // Confidence  confidenceScore Int @map("confidence_score")  // Status  status RecommendationStatus @default(PENDING)  // Implementation  implementedFeedingId String?   @map("implemented_feeding_id") @db.Uuid  implementedDate      DateTime? @map("implemented_date") @db.Timestamptz  // Evaluation  outcomeRating Int?    @map("outcome_rating")  outcomeNotes  String? @map("outcome_notes")  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz  expiresAt DateTime? @map("expires_at") @db.Timestamptz  // Relations  apiary Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  hive   Hive?  @relation(fields: [hiveId], references: [id])  @@index([apiaryId, recommendationDate(sort: Desc)])  @@index([status])  @@map("feeding_recommendation")}model FeedingSchedule {  id       String  @id @default(uuid()) @db.Uuid  apiaryId String  @map("apiary_id") @db.Uuid  hiveId   String? @map("hive_id") @db.Uuid  // Schedule  scheduleName String    @map("schedule_name")  startDate    DateTime  @map("start_date") @db.Date  endDate      DateTime? @map("end_date") @db.Date  // Frequency  frequency  FeedingFrequency  customDays Int[]            @map("custom_days")  // Feeding Details  feedingType        String  @map("feeding_type")  feedingLocation    String  @map("feeding_location")  quantityPerFeeding Decimal @map("quantity_per_feeding") @db.Decimal(10, 2)  // Status  isActive Boolean @default(true) @map("is_active")  // Tracking  feedingsCompleted Int       @default(0) @map("feedings_completed")  feedingsPlanned   Int?      @map("feedings_planned")  lastFeedingDate   DateTime? @map("last_feeding_date") @db.Timestamptz  nextFeedingDate   DateTime? @map("next_feeding_date") @db.Date  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  apiary Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  hive   Hive?  @relation(fields: [hiveId], references: [id])  @@index([apiaryId])  @@index([nextFeedingDate])  @@map("feeding_schedule")}// ============================================================================// G. DISEASES (2 tables for MVP)// ============================================================================model DiseaseLibrary {  id String @id @default(uuid()) @db.Uuid  // Names  nameAr         String  @map("name_ar")  nameEn         String  @map("name_en")  scientificName String? @map("scientific_name")  // Classification  diseaseType    DiseaseType  severity       DiseaseSeverity  contagiousness Contagiousness  mortalityRate  Int?            @map("mortality_rate")  // Symptoms  symptoms Json  // Diagnosis  diagnosisMethods Json? @map("diagnosis_methods")  // Treatment  treatable Boolean @default(true)  // Drastic Measures  burningRequired        Boolean @default(false) @map("burning_required")  quarantineRequired     Boolean @default(false) @map("quarantine_required")  quarantineDurationDays Int?    @map("quarantine_duration_days")  reportingMandatory     Boolean @default(false) @map("reporting_mandatory")  // Prevention  preventionMethods String[] @map("prevention_methods")  // Media  images String[]  videos String[]  // References  references Json?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  diseaseRecords DiseaseRecord[]  treatments     DiseaseTreatment[]  @@index([diseaseType])  @@index([severity])  @@map("disease_library")}model DiseaseTreatment {  id        String @id @default(uuid()) @db.Uuid  diseaseId String @map("disease_id") @db.Uuid  // Treatment Details  nameAr      String        @map("name_ar")  nameEn      String        @map("name_en")  description String?  type        TreatmentType // e.g. CHEMICAL, ORGANIC, PHYSICAL  // Application  applicationMethod String  @map("application_method")  dosage            String?  durationDays      Int?    @map("duration_days")  frequency         String? // e.g. "Once a week"  // Constraints  season           String[] // e.g. ["SPRING", "FALL"]  temperatureMin   Int?     @map("temperature_min")  temperatureMax   Int?     @map("temperature_max")  honeySafe        Boolean  @default(false) @map("honey_safe")  withdrawalPeriod Int?     @map("withdrawal_period") // Days before harvest  // Effectiveness  effectiveness Int? @map("effectiveness") // 1-100%  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  disease        DiseaseLibrary @relation(fields: [diseaseId], references: [id], onDelete: Cascade)  treatmentPlans TreatmentPlan[]  @@index([diseaseId])  @@map("disease_treatment")}enum TreatmentType {  CHEMICAL  ORGANIC  PHYSICAL  BIOLOGICAL  MANAGEMENT  DIETARY  @@map("treatment_type")}model DiseaseRecord {  id        String @id @default(uuid()) @db.Uuid  apiaryId  String @map("apiary_id") @db.Uuid  diseaseId String @map("disease_id") @db.Uuid  // Detection  firstDetectedDate DateTime @map("first_detected_date") @db.Timestamptz  detectedBy        String   @map("detected_by") @db.Uuid  // Confirmation  confirmed          Boolean   @default(false)  confirmationMethod String?   @map("confirmation_method")  confirmationDate   DateTime? @map("confirmation_date") @db.Timestamptz  // Spread  affectedHives      String[] @map("affected_hives") @db.Uuid  totalAffectedHives Int      @map("total_affected_hives")  percentageOfApiary Decimal? @map("percentage_of_apiary") @db.Decimal(5, 2)  spreading  Boolean  @default(false)  spreadRate Decimal? @map("spread_rate") @db.Decimal(5, 2)  // Status  status DiseaseStatus @default(ACTIVE)  // Treatment (simplified for MVP)  treatmentNotes String? @map("treatment_notes")  // Drastic Actions  drasticActions Json? @map("drastic_actions")  // Reporting  reportedToAuthorities Boolean   @default(false) @map("reported_to_authorities")  reportDate            DateTime? @map("report_date") @db.Timestamptz  authorityResponse     String?   @map("authority_response")  // Community Alert  communityAlertSent Boolean @default(false) @map("community_alert_sent")  // Resolution  resolutionDate DateTime? @map("resolution_date") @db.Timestamptz  outcome        String?  // Statistics  hivesDestroyed Int      @default(0) @map("hives_destroyed")  hivesRecovered Int      @default(0) @map("hives_recovered")  financialLoss  Decimal? @map("financial_loss") @db.Decimal(10, 2)  notes String?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  apiary   Apiary         @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  disease  DiseaseLibrary @relation(fields: [diseaseId], references: [id])  detector UserProfile    @relation(fields: [detectedBy], references: [id])  hives    Hive[]  treatmentPlans TreatmentPlan[]  @@index([apiaryId, firstDetectedDate(sort: Desc)])  @@index([status])  @@map("disease_record")}// ============================================================================// G2. TREATMENT PLANS Ã¢â‚¬â€ Links a DiseaseRecord to an adopted DiseaseTreatment// ============================================================================model TreatmentPlan {  id                 String     @id @default(uuid()) @db.Uuid  diseaseRecordId    String     @map("disease_record_id") @db.Uuid  diseaseTreatmentId String     @map("disease_treatment_id") @db.Uuid  // Scheduling  startDate          DateTime   @map("start_date") @db.Timestamptz  expectedEndDate    DateTime?  @map("expected_end_date") @db.Timestamptz  actualEndDate      DateTime?  @map("actual_end_date") @db.Timestamptz  status             PlanStatus @default(IN_PROGRESS)  // Step tracking (JSON array of completed step indices from the protocol)  completedSteps     Json?      @map("completed_steps")  // Cost tracking  costIncurred       Decimal?   @map("cost_incurred") @db.Decimal(10, 2)  // Outcome  userRating         Int?       @map("user_rating") // 1-5  userFeedback       String?    @map("user_feedback")  notes              String?  createdAt          DateTime   @default(now()) @map("created_at") @db.Timestamptz  updatedAt          DateTime   @updatedAt @map("updated_at") @db.Timestamptz  // Relations  diseaseRecord      DiseaseRecord    @relation(fields: [diseaseRecordId], references: [id], onDelete: Cascade)  treatment          DiseaseTreatment @relation(fields: [diseaseTreatmentId], references: [id])  @@index([diseaseRecordId])  @@index([status])  @@map("treatment_plan")}enum PlanStatus {  IN_PROGRESS  COMPLETED  ABORTED  @@map("plan_status")}// ============================================================================// H. HARVEST (3 tables for MVP)// ============================================================================model HarvestRecord {  id       String @id @default(uuid()) @db.Uuid  apiaryId String @map("apiary_id") @db.Uuid  // Type  harvestType HarvestType @map("harvest_type")  // Date  harvestDate DateTime @map("harvest_date") @db.Timestamptz  // Quantity  totalQuantity Decimal     @map("total_quantity") @db.Decimal(10, 2)  unit          HarvestUnit  // Quality  qualityGrade QualityGrade? @map("quality_grade")  qualityScore Int?          @map("quality_score")  // Details  details Json?  // Financial  estimatedValue Decimal? @map("estimated_value") @db.Decimal(10, 2)  pricePerUnit   Decimal? @map("price_per_unit") @db.Decimal(10, 2)  totalValue     Decimal? @map("total_value") @db.Decimal(10, 2)  // Media  images String[]  // Tracking  harvestedBy String?  @map("harvested_by") @db.Uuid  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz  notes String?  // Relations  apiary                Apiary                 @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  honeyHarvests         HoneyHarvest[]  pollenHarvests        Po