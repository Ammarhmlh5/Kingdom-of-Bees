) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  apiary     Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  motherHive Hive   @relation("MotherHive", fields: [motherHiveId], references: [id])  @@index([apiaryId, splitDate(sort: Desc)])  @@map("split_operation")}model MergeOperation {  id             String @id @default(uuid()) @db.Uuid  apiaryId       String @map("apiary_id") @db.Uuid  survivorHiveId String @map("survivor_hive_id") @db.Uuid  mergedHiveId   String @map("merged_hive_id") @db.Uuid  // Date  mergeDate DateTime @map("merge_date") @db.Date  // Method  method        MergeMethod  methodDetails Json?       @map("method_details")  // Outcome  outcome Json  // Equipment Recovered  equipmentRecovered Json? @map("equipment_recovered")  // Financial  financialAnalysis Json? @map("financial_analysis")  notes String?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  apiary       Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  survivorHive Hive   @relation("SurvivorHive", fields: [survivorHiveId], references: [id])  mergedHive   Hive   @relation("MergedHive", fields: [mergedHiveId], references: [id])  @@index([apiaryId, mergeDate(sort: Desc)])  @@map("merge_operation")}model ConsolidationOperation {  id     String @id @default(uuid()) @db.Uuid  hiveId String @map("hive_id") @db.Uuid  // Date  consolidationDate DateTime @map("consolidation_date") @db.Date  // Before & After  beforeState Json @map("before_state")  afterState  Json @map("after_state")  // Procedure  procedureDetails Json @map("procedure_details")  // Winter Readiness  winterReadiness Json? @map("winter_readiness")  // Equipment Recovered  equipmentRecovered Json? @map("equipment_recovered")  notes String?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  hive Hive @relation(fields: [hiveId], references: [id], o