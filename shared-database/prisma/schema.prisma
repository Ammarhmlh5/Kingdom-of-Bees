averagePerCupMg    Decimal @map("average_per_cup_mg") @db.Decimal(10, 2)  // Quality  qualityGrade QualityGrade? @map("quality_grade")  color        String?  consistency  String?  // Value  pricePerGram Decimal? @map("price_per_gram") @db.Decimal(10, 2)  totalValue   Decimal? @map("total_value") @db.Decimal(10, 2)  // Cost & ROI  productionCost Decimal? @map("production_cost") @db.Decimal(10, 2)  netProfit      Decimal? @map("net_profit") @db.Decimal(10, 2)  roiPercentage  Decimal? @map("roi_percentage") @db.Decimal(10, 2)  // Evaluation  successRating Int? @map("success_rating")  notes     String?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  hive          Hive           @relation(fields: [hiveId], references: [id], onDelete: Cascade)  harvestRecord HarvestRecord? @relation(fields: [id], references: [id])  @@map("royal_jelly_production")}// ============================================================================// ADDITIONAL ENUMS// ============================================================================enum QueenSource {  BRED  PURCHASED  SWARM  SPLIT  UNKNOWN  @@map("queen_source")}enum EggLayingRate {  EXCELLENT  VERY_GOOD  GOOD  FAIR  POOR  @@map("egg_laying_rate")}enum QueenStatus {  ACTIVE  MATING  LAYING  FAILING  DEAD  SOLD  LOST  @@map("queen_status")}enum NucleusQueenStatus {  VIRGIN  MATING  LAYING  FAILING  ABSENT  @@map("nucleus_queen_status")}enum NucleusPurpose {  QUEEN_MATING  QUEEN_STORAGE  HIVE_INCREASE  SALE  OTHER  @@map("nucleus_purpose")}enum NucleusStatus {  ACTIVE  WEAK  QUEENLESS  GRADUATED  MERGED  SOLD  LOST  @@map("nucleus_status")}enum FeedingLocation {  INTERNAL  EXTERNAL  @@map("feeding_location")}enum FeedingMethod {  TOP_FEEDER  FRAME_FEEDER  ENTRANCE_FEEDER  BULK_FEEDER  SPRAY  OTHER  @@map("feeding_method")}enum FeedingContentType {  SUGAR_SYRUP  PROTEIN  POLLEN_SUBSTITUTE  FONDANT  MEDICINAL  SUPPLEMENT  OTHER  @@map("feeding_content_type")}enum FeedingPurpose {  STIMULATION  MAINTENANCE  EMERGENCY  TREATMENT  WINTER_PREP  SPRING_BUILDUP  @@map("feeding_purpose")}enum HoneyQualityImpact {  NONE  LOW  MEDIUM  HIGH  CRITICAL  @@map("honey_quality_impact")}enum FeedingUrgency {  IMMEDIATE  TODAY  THIS_WEEK  SOON  @@map("feeding_urgency")}enum RecommendationStatus {  PENDING  ACCEPTED  REJECTED  COMPLETED  EXPIRED  @@map("recommendation_status")}enum FeedingFrequency {  DAILY  EVERY_2_DAYS  EVERY_3_DAYS  WEEKLY  CUSTOM  @@map("feeding_frequency")}enum DiseaseType {  BACTERIAL  VIRAL  FUNGAL  PARASITIC  PEST  GENETIC  NUTRITIONAL  @@map("disease_type")}enum DiseaseSeverity {  CATASTROPHIC  SEVERE  MODERATE  MILD  @@map("disease_severity")}enum Contagiousness {  EXTREMELY_HIGH  HIGH  MEDIUM  LOW  NONE  @@map("contagiousness")}enum DiseaseStatus {  ACTIVE  TREATING  RESOLVED  CATASTROPHIC  @@map("disease_status")}enum HarvestType {  HONEY  POLLEN  ROYAL_JELLY  PROPOLIS  WAX  BEE_VENOM  @@map("harvest_type")}enum HarvestUnit {  KG  GRAM  LITER  @@map("harvest_unit")}enum QualityGrade {  PREMIUM  GRADE_A  GRADE_B  GRADE_C  REJECT  @@map("quality_grade")}enum PollenCollectionMethod {  POLLEN_TRAP  FRAME_TRANSFER  @@map("pollen_collection_method")}enum SplitMethod {  STANDARD  WITH_NUCLEUS_QUEENS  WITH_PURCHASED_QUEENS  MIXED  @@map("split_method")}enum OperationStatus {  PLANNED  IN_PROGRESS  MONITORING  COMPLETED  FAILED  @@map("operation_status")}enum MergeMethod {  NEWSPAPER  DIRECT  GRADUAL  SPRAY  @@map("merge_method")}enum SwarmEventType {  SWARMED  CAPTURED  PREVENTED  OBSERVED  @@map("swarm_event_type")}enum SwarmSize {  SMALL  MEDIUM  LARGE  VERY_LARGE  @@map("swarm_size")}enum WeatherSource {  API  MANUAL  SENSOR  @@map("weather_source")}enum BeeFlightConditions {  EXCELLENT  GOOD  FAIR  POOR  IMPOSSIBLE  @@map("bee_flight_conditions")}enum WeatherEventType {  DROUGHT  EXCESSIVE_RAIN  FROST  HEATWAVE  STORM  FAVORABLE_PERIOD  @@map("weather_event_type")}enum PlantType {  TREE  SHRUB  HERB  CROP  WILDFLOWER  @@map("plant_type")}enum CoverageUnit {  HECTARES  TREES  PATCHES  @@map("coverage_unit")}enum PlantDensity {  VERY_DENSE  DENSE  SCATTERED  SPARSE  RARE  @@map("plant_density")}enum LocalPlantStatus {  ACTIVE  BLOOMING  ENDED  REMOVED  @@map("local_plant_status")}enum BeeActivityLevel {  VERY_HIGH  HIGH  MODERATE  LOW  VERY_LOW  NONE  @@map("bee_activity_level")}enum BloomStatus {  PEAK  HIGH  MODERATE  BEGINNING  ENDING  NOT_BLOOMING  @@map("bloom_status")}enum SyncAction {  CREATE  UPDATE  DELETE  @@map("sync_action")}enum QueueStatus {  PENDING  PROCESSING  COMPLETED  FAILED  @@map("queue_status")}enum AlertStatus {  ACTIVE  ACKNOWLEDGED  DISMISSED  RESOLVED  EXPIRED  @@map("alert_status")}enum FeedbackType {  BUG  FEATURE_REQUEST  IMPROVEMENT  PRAISE  COMPLAINT  OTHER  @@map("feedback_type")}enum FeedbackStatus {  SUBMITTED  REVIEWING  PLANNED  IMPLEMENTED  REJECTED  DUPLICATE  @@map("feedback_status")}model Product {  id          String        @id @default(uuid()) @db.Uuid  name        String  category    String  description String?  price       Decimal       @db.Decimal(10, 2)  stock       Int           @default(0)  status      String        @default("ACTIVE")  imageUrl    String?       @map("image_url")  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz  updatedAt   DateTime      @updatedAt @map("updated_at") @db.Timestamptz  ProductUnit ProductUnit[]  @@map("product")}// ============================================================================// E. NEW MODULES (Next-Gen Features)// ============================================================================// ----------------------------------------------------------------------------// 1. Hive Templates (From Active Project)// ----------------------------------------------------------------------------model HiveTemplate {  id          String  @id @default(uuid()) @db.Uuid  name        String  description String?  // Configuration  // Configuration  hiveTypeId   String   @map("hive_type_id") @db.Uuid  hiveType     HiveType @relation(fields: [hiveTypeId], references: [id])  stories      Int      @default(1)  framesPerBox Int      @default(10) @map("frames_per_box")  frameSize    String?  @map("frame_size")  // Defaults  defaultNotes String?  @map("default_notes")  defaultTags  String[] @map("default_tags")  isActive  Boolean  @default(true) @map("is_active")  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  createdBy String?      @map("created_by") @db.Uuid  user      UserProfile? @relation(fields: [createdBy], references: [id])  @@map("hive_template")}// ----------------------------------------------------------------------------// 2. AI Chat & Personalization (New)// ----------------------------------------------------------------------------enum ChatMode {  ADVISOR  DIAGNOSTIC  GENERAL  ANALYSIS}model AIChatSession {  id      String   @id @default(uuid()) @db.Uuid  userId  String   @map("user_id") @db.Uuid  title   String?  mode    ChatMode  context Json?    @db.JsonB // { "active_hive": "uuid", "current_problem": "varroa" }  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  user     UserProfile     @relation(fields: [userId], references: [id], onDelete: Cascade)  messages AIChatMessage[]  @@index([userId, updatedAt(sort: Desc)])  @@map("ai_chat_session")}model AIChatMessage {  id        String @id @default(uuid()) @db.Uuid  sessionId String @map("session_id") @db.Uuid  role      String // USER, AI, SYSTEM  content   String  // RAG & Citations  sources Json? @db.JsonB // [ { "type": "COMMUNITY_STAT", "id": "stat-99" }, { "type": "SCIENCE_ARTICLE", "url": "..." } ]  // Feedback  feedback Int? // 1-5 rating  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  session AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)  @@index([sessionId, createdAt(sort: Asc)])  @@map("ai_chat_message")}model AIUserContext {  userId String @id @map("user_id") @db.Uuid  // Inferred Profile  experienceLevel String   @map("experience_level") // "BEGINNER", "EXPERT"  interests       String[]  lastFocus       String?  @map("last_focus")  // Preferences  learnedPreferences Json @map("learned_preferences") @db.JsonB  lastUpdated DateTime @updatedAt @map("last_updated") @db.Timestamptz  // Relations  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)  @@map("ai_user_context")}model AICommunityInsight {  id             String  @id @default(uuid()) @db.Uuid  topic          String  region         String?  finding        String  confidence     Decimal @db.Decimal(5, 2) // 95.50  basedOnSamples Int     @map("based_on_samples")  lastUpdated DateTime @updatedAt @map("last_updated") @db.Timestamptz  @@index([topic, region])  @@map("ai_community_insight")}// ----------------------------------------------------------------------------// 3. IoT & Telemetry (New)// ----------------------------------------------------------------------------enum DeviceType {  SMART_SCALE  TEMP_HUMIDITY  AUDIO_MONITOR  GPS_TRACKER  CAMERA  WEATHER_STATION}model HiveSensor {  id       String  @id @default(uuid()) @db.Uuid  hiveId   String? @map("hive_id") @db.Uuid  apiaryId String? @map("apiary_id") @db.Uuid  name            String  deviceType      DeviceType @map("device_type")  serialNumber    String     @unique @map("serial_number")  firmwareVersion String?    @map("firmware_version")  // Status  batteryLevel   Int?      @map("battery_level")  signalStrength Int?      @map("signal_strength")  lastSync       DateTime? @map("last_sync") @db.Timestamptz  isActive       Boolean   @default(true) @map("is_active")  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  hive     Hive?           @relation(fields: [hiveId], references: [id])  apiary   Apiary?         @relation(fields: [apiaryId], references: [id])  readings SensorReading[]  @@map("hive_sensor")}model SensorReading {  // Hypertable candidate (Time-series)  id       String @id @default(uuid()) @db.Uuid // Optional in pure time-series db  sensorId String @map("sensor_id") @db.Uuid  timestamp DateTime @map("timestamp") @db.Timestamptz  // Data  temperature Decimal? @db.Decimal(5, 2)  humidity    Decimal? @db.Decimal(5, 2)  weightKg    Decimal? @map("weight_kg") @db.Decimal(6, 3)  frequencyHz Decimal? @map("frequency_hz") @db.Decimal(8, 2) // Audio analysis  rawPayload Json? @map("raw_payload") @db.JsonB  // Relations  sensor HiveSensor @relation(fields: [sensorId], references: [id], onDelete: Cascade)  @@index([sensorId, timestamp(sort: Desc)])  @@map("sensor_reading")}// ----------------------------------------------------------------------------// 4. Advanced Supply Chain (Traceability)// ----------------------------------------------------------------------------model HoneyBatch {  id        String @id @default(uuid()) @db.Uuid  batchCode String @unique @map("batch_code") // GR-2025-001  // Origin  apiaryIds   String[] @map("apiary_ids") @db.Uuid // Denormalized for quick lookup  harvestDate DateTime @map("harvest_date") @db.Date  // Details  floralSource    String? @map("floral_source")  totalQuantityKg Decimal @map("total_quantity_kg") @db.Decimal(10, 2)  // Processing  processingStatus String @default("RAW") @map("processing_status")  // Traceability  qrCodeUrl      String? @map("qr_code_url")  blockchainHash String? @map("blockchain_hash")  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  harvests     HoneyHarvest[] // Need to update HoneyHarvest to point here  labResults   LabTestResult[]  productUnits ProductUnit[]  @@map("honey_batch")}model LabTestResult {  id      String @id @default(uuid()) @db.Uuid  batchId String @map("batch_id") @db.Uuid  testType String   @map("test_type") // HMF, Sugar, Moisture  labName  String?  @map("lab_name")  testDate DateTime @map("test_date") @db.Date  value  Decimal @db.Decimal(10, 4)  unit   String  passed Boolean  certificateUrl String? @map("certificate_url")  // Relations  batch HoneyBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)  @@map("lab_test_result")}model ProductUnit {  id        String @id @default(uuid()) @db.Uuid  batchId   String @map("batch_id") @db.Uuid  productId String @map("product_id") @db.Uuid // From Product table  serialCode String   @unique @map("serial_code")  packedDate DateTime @map("packed_date") @db.Date  sold   Boolean   @default(false)  soldAt DateTime? @map("sold_at") @db.Timestamptz  // Relations  batch   HoneyBatch @relation(fields: [batchId], references: [id])  product Product    @relation(fields: [productId], references: [id])  @@map("product_unit")}// ============================================================================// F. ADMIN & SAAS MODULES (Admin Panel Addons)// ============================================================================// ----------------------------------------------------------------------------// 1. Subscription & Billing// ----------------------------------------------------------------------------model BillingPlan {  id          String  @id @default(uuid()) @db.Uuid  code        String  @unique // FREE, PRO_MONTHLY, ENT_YEARLY  name        String  description String?  price    Decimal @db.Decimal(10, 2)  currency String  @default("USD")  interval String // MONTHLY, YEARLY  // Limits  maxApiaries Int  @default(1) @map("max_apiaries")  maxHives    Int  @default(10) @map("max_hives")  features    Json @default("{}") // { "ai_advisor": true, "offline_mode": false }  isActive  Boolean  @default(true) @map("is_active")  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  subscribers UserProfile[]  @@map("billing_plan")}model Invoice {  id     String @id @default(uuid()) @db.Uuid  userId String @map("user_id") @db.Uuid  amount   Decimal @db.Decimal(10, 2)  currency String  @default("USD")  status   String // PAID, PENDING, FAILED, REFUNDED  billingDate DateTime  @default(now()) @map("billing_date") @db.Timestamptz  dueDate     DateTime  @map("due_date") @db.Timestamptz  paidAt      DateTime? @map("paid_at") @db.Timestamptz  invoiceUrl String? @map("invoice_url")  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  user     UserProfile @relation(fields: [userId], references: [id])  payments Payment[]  @@index([userId])  @@map("invoice")}// ----------------------------------------------------------------------------// 2. AI Governance (Aggregated Stats)// ----------------------------------------------------------------------------model AITrainingStat {  id   String   @id @default(uuid()) @db.Uuid  date DateTime @unique @db.Date  totalInteractions Int @default(0) @map("total_interactions")  // Feedback Stats  positiveFeedbackCount Int @default(0) @map("positive_feedback_count")  negativeFeedbackCount Int @default(0) @map("negative_feedback_count")  // Topics (Aggregated JSON)  topicDistribution Json @default("{}") // { "disease": 200, "weather": 150 }  accuracyScore Decimal? @map("accuracy_score") @db.Decimal(5, 2)  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  @@map("ai_training_stat")}// ----------------------------------------------------------------------------// 3. System Infrastructure// ----------------------------------------------------------------------------model SystemLog {  id        String @id @default(uuid()) @db.Uuid  level     String // INFO, WARN, ERROR, CRITICAL  component String // API, DB, WORKER, AI  message   String  metadata Json?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  @@index([level])  @@index([createdAt(sort: Desc)])  @@map("system_log")}// ============================================================================// G. APIARY WORKSPACE COMPLETION (Added 2026-04-19)// ============================================================================// Financial Records (Revenues & Expenses per Apiary)model FinancialRecord {  id       String @id @default(uuid()) @db.Uuid  apiaryId String @map("apiary_id") @db.Uuid  // Type  type FinancialType  // Amount  amount   Decimal @db.Decimal(12, 2)  currency String  @default("SAR")  // Category  category    String  description String?  // Date  recordDate DateTime @map("record_date") @db.Date  // Tracking  createdBy String?  @map("created_by") @db.Uuid  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  apiary  Apiary       @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  creator UserProfile? @relation("FinancialRecordCreator", fields: [createdBy], references: [id])  @@index([apiaryId, recordDate(sort: Desc)])  @@index([apiaryId, type])  @@map("financial_record")}enum FinancialType {  REVENUE  EXPENSE  @@map("financial_type")}// Unified Operations Log (All apiary operations in one place)model ApiaryOperation {  id       String @id @default(uuid()) @db.Uuid  apiaryId String @map("apiary_id") @db.Uuid  // Sequential number per apiary (auto-generated)  operationNumber Int @map("operation_number")  // Type  operationType ApiaryOperationType @map("operation_type")  // Related Hive (optional)  hiveId String? @map("hive_id") @db.Uuid  // Description  description String  // Performer  performedBy String? @map("performed_by") @db.Uuid  // Date  operationDate DateTime @map("operation_date") @db.Timestamptz  // Link to source record  sourceRecordId String? @map("source_record_id") @db.Uuid  sourceType     String? @map("source_type")  // Extra data (JSON)  data Json @default("{}")  // Tracking  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  apiary           Apiary              @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  hive             Hive?               @relation("ApiaryOperationHive", fields: [hiveId], references: [id], onDelete: SetNull)  performer        UserProfile?        @relation("ApiaryOperationPerformer", fields: [performedBy], references: [id])  sourceAnalyses   OperationAnalysis[]  resolvingMatches PredictionMatch[]   @relation("ResolvingOperationMatches")  @@unique([apiaryId, operationNumber])  @@index([apiaryId, operationDate(sort: Desc)])  @@index([apiaryId, operationType])  @@map("apiary_operation")}enum ApiaryOperationType {  INSPECTION  FEEDING  HARVEST  SPLIT  MERGE  TREATMENT  ADD_SUPER  OTHER  @@map("apiary_operation_type")}// ============================================================================// H. ADMIN PANEL ENHANCEMENT (Added 2026-04-21)// ============================================================================// ----------------------------------------------------------------------------// 1. Admin Roles & Permissions// ----------------------------------------------------------------------------model AdminRole {  id String @id @default(uuid()) @db.Uuid  // Basic Information  name        String  @unique  nameAr      String  @map("name_ar")  description String?  // Permissions (JSON structure)  permissions Json @default("{}") // { "users": ["read", "write"], "apiaries": ["read"] }  // System Role (cannot be deleted/modified)  isSystem Boolean @default(false) @map("is_system")  // Status  isActive Boolean @default(true) @map("is_active")  // Tracking  createdBy String?  @map("created_by") @db.Uuid  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  creator         UserProfile?      @relation("RoleCreator", fields: [createdBy], references: [id])  userPermissions AdminPermission[]  users           UserProfile[]     @relation("UserAdminRole")  @@index([isActive])  @@index([isSystem])  @@index([createdBy])  @@map("admin_role")}model AdminPermission {  id String @id @default(uuid()) @db.Uuid  // User & Role  userId String  @map("user_id") @db.Uuid  roleId String? @map("role_id") @db.Uuid  // Resource & Action  resource String // e.g., "users", "apiaries", "settings"  action   String // e.g., "read", "write", "delete", "approve"  // Permission Status  granted Boolean @default(true)  // Scope (optional - for fine-grained control)  scope Json? // e.g., { "apiaryId": "uuid" } for apiary-specific permission  // Temporary Access  expiresAt DateTime? @map("expires_at") @db.Timestamptz  // Tracking  grantedBy String?  @map("granted_by") @db.Uuid  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz  // Relations  user    UserProfile  @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)  role    AdminRole?   @relation(fields: [roleId], references: [id], onDelete: Cascade)  grantor UserProfile? @relation("PermissionGrantor", fields: [grantedBy], references: [id])  @@unique([userId, resource, action])  @@index([userId])  @@index([roleId])  @@index([resource, action])  @@index([expiresAt])  @@map("admin_permission")}// ----------------------------------------------------------------------------// 2. Audit Logs// ----------------------------------------------------------------------------model AuditLog {  id String @id @default(uuid()) @db.Uuid  // User Information  userId    String? @map("user_id") @db.Uuid  userName  String? @map("user_name")  userEmail String? @map("user_email")  // Action Details  action       String // e.g., "CREATE_USER", "UPDATE_APIARY", "DELETE_DISEASE"  resourceType String  @map("resource_type") // e.g., "USER", "APIARY", "DISEASE"  resourceId   String? @map("resource_id") @db.Uuid  // Changes (before/after)  details Json? // { before: {...}, after: {...}, changes: [...] }  // Request I