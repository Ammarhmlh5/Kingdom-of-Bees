pe String @map("recommendation_type")  // Input/Output  inputData       Json     @map("input_data")  recommendation  Json  confidenceScore Decimal? @map("confidence_score") @db.Decimal(5, 2)  // Model  modelVersion String? @map("model_version")  modelName    String? @map("model_name")  // Implementation  accepted    Boolean? @default(false)  implemented Boolean  @default(false)  // Evaluation  outcomeRating Int?    @map("outcome_rating")  outcomeNotes  String? @map("outcome_notes")  // Tracking  userId   String? @map("user_id") @db.Uuid  apiaryId String? @map("apiary_id") @db.Uuid  hiveId   String? @map("hive_id") @db.Uuid  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  user   UserProfile? @relation(fields: [userId], references: [id])  apiary Apiary?      @relation(fields: [apiaryId], references: [id])  hive   Hive?        @relation(fields: [hiveId], references: [id])  @@index([recommendationType, createdAt(sort: Desc)])  @@map("ai_recommendation_log")}model Alert {  id String @id @default(uuid()) @db.Uuid  // Target  userId   String? @map("user_id") @db.Uuid  apiaryId String? @map("apiary_id") @db.Uuid  hiveId   String? @map("hive_id") @db.Uuid  // Content  alertType String         @map("alert_type")  priority  ActionPriority  title   String  message String  // Action  actionRequired Boolean   @default(false) @map("action_required")  actionUrl      String?   @map("action_url")  actionDeadline DateTime? @map("action_deadline") @db.Timestamptz  // Status  status AlertStatus @default(ACTIVE)  acknowledgedAt DateTime? @map("acknowledged_at") @db.Timestamptz  acknowledgedBy String?   @map("acknowledged_by") @db.Uuid  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz  // Tracking  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz  expiresAt DateTime? @map("expires_at") @db.Timestamptz  // Relations  user         UserProfile? @relation(fields: [userId], references: [id])  apiary       Apiary?      @relation