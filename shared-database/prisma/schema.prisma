ult(false)  verifiedBy String?  @map("verified_by") @db.Uuid  // Relations  localPlants LocalPlant[]  @@index([plantType])  @@map("plant_library")}model LocalPlant {  id       String @id @default(uuid()) @db.Uuid  apiaryId String @map("apiary_id") @db.Uuid  plantId  String @map("plant_id") @db.Uuid  // Location  locationLat Decimal? @map("location_lat") @db.Decimal(10, 8)  locationLng Decimal? @map("location_lng") @db.Decimal(11, 8)  distanceKm  Decimal? @map("distance_km") @db.Decimal(10, 2)  direction   String?  description String?  // Abundance  coverage       Decimal       @db.Decimal(10, 2)  coverageUnit   CoverageUnit  @map("coverage_unit")  density        PlantDensity?  abundanceScore Int?          @map("abundance_score")  // Bee Attraction  beeAttraction Json @default("{}") @map("bee_attraction")  // Local Blooming  localBlooming Json? @map("local_blooming")  // Estimated Production  estimatedProduction Json? @map("estimated_production")  // Status  status LocalPlantStatus @default(ACTIVE)  // Tracking  addedDate   DateTime @default(now()) @map("added_date") @db.Date  addedBy     String?  @map("added_by") @db.Uuid  lastUpdated DateTime @default(now()) @map("last_updated") @db.Timestamptz  notes  String?  images String[]  // Relations  apiary       Apiary             @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  plant        PlantLibrary       @relation(fields: [plantId], references: [id])  observations PlantObservation[]  @@index([apiaryId])  @@index([plantId])  @@index([status])  @@map("local_plant")}model PlantObservation {  id           String @id @default(uuid()) @db.Uuid  localPlantId String @map("local_plant_id") @db.Uuid  // Date & Time  observationDate DateTime  @map("observation_date") @db.Timestamptz  observationTime DateTime? @map("observation_time") @db.Time  // Activity  beeActivityLevel  BeeActivityLevel @map("bee_activity_level")  estimatedBeeCount Int?             @map("estimated_bee_count")  // Conditions  weatherConditions  String?  @map("weather_conditions")  temperatureCelsius Decimal? @map("temperature_celsius") @db.Decimal(5, 2)  // Blooming  bloomStatus    BloomStatus? @map("bloom_status")  bloomIntensity Int?         @map("bloom_intensity")  // Notes  notes  String?  images String[]  // Tracking  observedBy String?  @map("observed_by") @db.Uuid  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  localPlant LocalPlant   @relation(fields: [localPlantId], references: [id], onDelete: Cascade)  observer   UserProfile? @relation(fields: [observedBy], references: [id])  @@index([localPlantId, observationDate(sort: Desc)])  @@map("plant_observation")}model ForageAssessment {  id       String @id @default(uuid()) @db.Uuid  apiaryId String @map("apiary_id") @db.Uuid  // Assessment  assessmentDate DateTime @default(now()) @map("assessment_date") @db.Timestamptz  // Overall  overallScore  Int               @map("overall_score")  overallRating OverallAssessment @map("overall_rating")  sufficient    Boolean  status        String  // Plant Analysis  plantAnalysis Json @map("plant_analysis")  // Carrying Capacity  carryingCapacity Json @map("carrying_capacity")  // Competition Analysis  competitionAnalysis Json @map("competition_analysis")  // Expected Production  expectedProduction Json? @map("expected_production")  // Annual Calendar  annualCalendar Json? @map("annual_calendar")  // Risks & Recommendations  risks           Json @default("[]")  recommendations Json @default("[]")  // Trends  trends Json?  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  apiary Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  @@index([apiaryId, assessmentDate(sort: Desc)])  @@map("forage_assessment")}// ============================================================================// L. SYSTEM & HELPERS (7 tables)// ============================================================================model SyncEvent {  id  