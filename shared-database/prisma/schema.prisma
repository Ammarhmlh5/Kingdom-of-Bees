_type")}// ============================================================================// I. PREDICTIVE ANALYTICS & MATCHING ENGINE (Added 2026-06-29)// ============================================================================model OperationAnalysis {  id                String   @id @default(uuid()) @db.Uuid  apiaryId          String   @map("apiary_id") @db.Uuid  hiveId            String   @map("hive_id") @db.Uuid  sourceOperationId String   @map("source_operation_id") @db.Uuid  analysisType      String   @map("analysis_type")  predictionPayload Json     @map("prediction_payload")  confidenceScore   Decimal? @db.Decimal(5, 2) @map("confidence_score")  isResolved        Boolean  @default(false) @map("is_resolved")  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz  // Relations  apiary          Apiary           @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  hive            Hive             @relation(fields: [hiveId], references: [id], onDelete: Cascade)  sourceOperation ApiaryOperation  @relation(fields: [sourceOperationId], references: [id], onDelete: Cascade)  predictionMatch PredictionMatch?  @@index([apiaryId, hiveId, isResolved])  @@map("operation_analysis")}model PredictionMatch {  id                   String   @id @default(uuid()) @db.Uuid  apiaryId             String   @map("apiary_id") @db.Uuid  analysisId           String   @unique @map("analysis_id") @db.Uuid  resolvingOperationId String   @map("resolving_operation_id") @db.Uuid  isAccurate        Boolean  @map("is_accurate")  accuracyScore     Decimal  @db.Decimal(5, 2) @map("accuracy_score")  predictedData     Json     @map("predicted_data")  actualOutcomeData Json     @map("actual_outcome_data")  matchedAt         DateTime @default(now()) @map("matched_at") @db.Timestamptz  // Relations  apiary             Apiary            @relation(fields: [apiaryId], references: [id], onDelete: Cascade)  analysis           OperationAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)  resolvingOperation ApiaryOperation   @relation("ResolvingOperationMatches", fields: [resolvingOperationId], references: [id], onDelete: Cascade)  @@index([apiaryId, isAccurate])  @@map("prediction_match")}// ============================================================================// I. INSPECTION SCHEDULING SYSTEM (Added 2026-07-02)// ============================================================================// ----------------------------------------------------------------------------// 1. Inspection Settings (Ã˜Â­Ã˜Â¯Ã™Ë†Ã˜Â¯ Ã˜Â§Ã™â€žÃ™ÂÃ˜Â­Ã˜Âµ Ã™â€žÃ™Æ’Ã™â€ž Ã™â€ Ã™Ë†Ã˜Â¹)// ----------------------------------------------------------------------------model InspectionSetting {  id          String   @id @default(uuid()) @db.Uuid  type        String   @unique // ROUTINE, QUICK_CHECK, DISEASE_CHECK, QUEEN_CHECK  nameAr      String   @map("name_ar") // Ã˜Â§Ã™â€žÃ˜Â§Ã˜Â³Ã™â€¦ Ã˜Â¨Ã˜Â§Ã™â€žÃ˜Â¹Ã˜Â±Ã˜Â¨Ã™Å   minInterval Int      @map("min_interval") // Ã˜Â§Ã™â€žÃ˜Â­Ã˜Â¯ Ã˜Â§Ã™â€žÃ˜Â£Ã˜Â¯Ã™â€ Ã™â€° (Ã˜Â¨Ã˜Â§Ã™â€žÃ˜Â£Ã™Å Ã˜Â§Ã™â€¦)  maxInterval Int      @map("max_interval") // Ã˜Â§Ã™â€žÃ˜Â­Ã˜Â¯ Ã˜Â§Ã™â€žÃ˜Â£Ã˜Â¹Ã™â€žÃ™â€° (Ã˜Â¨Ã˜Â§Ã™â€žÃ˜Â£Ã™Å Ã˜Â§Ã™â€¦)  isActive    Boolean  @default(true) @map("is_active")  description String?    // Tracking  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz    // Relations  schedules InspectionSchedule[]    @@map("inspection_setting")}// ----------------------------------------------------------------------------// 2. Inspection Schedule (Ã˜Â¬Ã˜Â¯Ã™Ë†Ã™â€žÃ˜Â© Ã˜Â§Ã™â€žÃ™ÂÃ˜Â­Ã™Ë†Ã˜ÂµÃ˜Â§Ã˜Âª)// ----------------------------------------------------------------------------model InspectionSchedule {  id            String    @id @default(uuid()) @db.Uuid  hiveId        String    @map("hive_id") @db.Uuid  settingId     String    @map("setting_id") @db.Uuid    // Ã˜Â§Ã™â€žÃ™â€¦Ã™Ë†Ã˜Â¹Ã˜Â¯ Ã˜Â§Ã™â€žÃ™â€¦Ã˜Â¬Ã˜Â¯Ã™Ë†Ã™â€ž  scheduledDate DateTime  @map("scheduled_date") @db.Timestamptz    // Ã˜Â§Ã™â€žÃ˜Â­Ã˜Â§Ã™â€žÃ˜Â©  status        String    @default("PENDING") @map("status") // PENDING, COMPLETED, MISSED, CANCELLED    // metadata  completedAt   DateTime? @map("completed_at") @db.Timestamptz  reminderSent  Boolean   @default(false) @map("reminder_sent")  notes         String?    // Tracking  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz    // Relations  hive    Hive             @relation(fields: [hiveId], references: [id], onDelete: Cascade)  setting InspectionSetting @relation(fields: [settingId], references: [id])    @@index([hiveId])  @@index([scheduledDate])  @@index([status])  @@map("inspection_schedule")}