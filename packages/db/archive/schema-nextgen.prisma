// Kingdom of Bees - Prisma Schema
// Database: PostgreSQL (Supabase)
// Version: 1.0
// Last Updated: December 18, 2025

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// A. USER MANAGEMENT (5 tables)
// ============================================================================

model UserProfile {
  id      String @id @default(uuid()) @db.Uuid
  authId  String @unique @map("auth_id") @db.Uuid // References auth.users in Supabase

  // Personal Information
  fullName String @map("full_name")
  email    String @unique
  phone    String?
  avatarUrl String? @map("avatar_url")

  // User Type
  userType UserType @default(EXPLORER) @map("user_type")

  // Location
  country String?
  region  String?
  city    String?

  // Settings
  language String @default("ar")
  timezone String @default("Asia/Riyadh")

  // Subscription
  subscriptionStatus SubscriptionStatus @default(FREE) @map("subscription_status")
  subscriptionPlan   SubscriptionPlan?  @map("subscription_plan")
  subscriptionStart  DateTime?          @map("subscription_start_date") @db.Timestamptz
  subscriptionEnd    DateTime?          @map("subscription_end_date") @db.Timestamptz

  // Tracking
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz

  // Status
  isActive   Boolean @default(true) @map("is_active")
  isVerified Boolean @default(false) @map("is_verified")

  // Statistics
  totalApiaries Int @default(0) @map("total_apiaries")
  totalHives    Int @default(0) @map("total_hives")

  // Relations
  ownedApiaries       Apiary[]              @relation("ApiaryOwner")
  apiaryMemberships   ApiaryMembership[]
  notifications       Notification[]
  activityLogs        UserActivityLog[]
  notificationSettings UserNotificationSettings?
  
  // Queen breeding
  queensBred          Queen[]               @relation("QueenBreeder")

  // Feeding records
  feedingRecords      FeedingRecord[]
  
  // Inspections
  inspections         Inspection[]
  
  // Disease records
  diseaseDetections   DiseaseRecord[]
  
  // Plant observations
  plantObservations   PlantObservation[]
  
  // Weather records
  weatherRecords      WeatherData[]
  
  // Operations (removed splitsPerformed due to constraint issues)
  
  // AI recommendations
  aiRecommendations   AIRecommendationLog[]
  
  // Alerts
  alerts              Alert[]
  alertsAcknowledged  Alert[]               @relation("AcknowledgedBy")
  
  // Feedback
  appFeedback         AppFeedback[]
  
  // Search history
  searchHistory       SearchHistory[]

  @@map("user_profile")
  @@index([email])
  @@index([userType])
}

model ApiaryMembership {
  id        String   @id @default(uuid()) @db.Uuid
  apiaryId  String   @map("apiary_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid

  // Role
  role        MemberRole @default(WORKER)
  permissions Json       @default("{ \"all\": true }")

  // Status
  status MembershipStatus @default(PENDING)

  // Tracking
  invitedBy String?   @map("invited_by") @db.Uuid
  invitedAt DateTime  @default(now()) @map("invited_at") @db.Timestamptz
  joinedAt  DateTime? @map("joined_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  apiary Apiary      @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  user   UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([apiaryId, userId])
  @@map("apiary_membership")
  @@index([apiaryId])
  @@index([userId])
}

model UserNotificationSettings {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  // Channels
  pushEnabled  Boolean @default(true) @map("push_enabled")
  emailEnabled Boolean @default(true) @map("email_enabled")
  smsEnabled   Boolean @default(false) @map("sms_enabled")

  // Types
  inspectionReminders Boolean @default(true) @map("inspection_reminders")
  feedingReminders    Boolean @default(true) @map("feeding_reminders")
  harvestReminders    Boolean @default(true) @map("harvest_reminders")
  diseaseAlerts       Boolean @default(true) @map("disease_alerts")
  swarmAlerts         Boolean @default(true) @map("swarm_alerts")
  weatherAlerts       Boolean @default(true) @map("weather_alerts")

  // Quiet Hours
  quietHoursStart DateTime? @map("quiet_hours_start") @db.Time
  quietHoursEnd   DateTime? @map("quiet_hours_end") @db.Time

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_settings")
}

model Notification {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  // Content
  title    String
  message  String
  type     NotificationType
  category String

  // Data
  data Json?

  // Action
  actionUrl   String? @map("action_url")
  actionLabel String? @map("action_label")

  // Status
  read   Boolean   @default(false)
  readAt DateTime? @map("read_at") @db.Timestamptz

  // Delivery
  sentVia Json @default("[]") @map("sent_via") // ['push', 'email']

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  // Relations
  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification")
  @@index([userId, createdAt(sort: Desc)])
  @@index([read])
}

model UserActivityLog {
  id     String @id @default(uuid()) @db.Uuid
  userId String @map("user_id") @db.Uuid

  // Activity
  action       String
  resourceType String? @map("resource_type")
  resourceId   String? @map("resource_id") @db.Uuid

  // Details
  details Json?

  // Device
  deviceInfo Json? @map("device_info")
  ipAddress  String? @map("ip_address") @db.Inet

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_activity_log")
  @@index([userId, createdAt(sort: Desc)])
  @@index([resourceType, resourceId])
}

// ============================================================================
// B. APIARY MANAGEMENT (3 tables)
// ============================================================================

model Apiary {
  id      String @id @default(uuid()) @db.Uuid
  ownerId String @map("owner_id") @db.Uuid

  // Basic Information
  name        String
  description String?

  // Type
  type ApiaryType

  // Location
  locationLat Decimal? @map("location_lat") @db.Decimal(10, 8)
  locationLng Decimal? @map("location_lng") @db.Decimal(11, 8)
  address     String?
  region      String?
  elevation   Int? // meters

  // Information
  establishedDate    DateTime? @map("established_date") @db.Date
  initialHiveCount   Int       @default(0) @map("initial_hive_count")
  currentHiveCount   Int       @default(0) @map("current_hive_count")

  // Settings
  settings Json @default("{}") // Strategy, preferences, etc.

  // Equipment
  equipment Json @default("{}") // Inventory of equipment

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Tracking
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  lastInspectionDate DateTime? @map("last_inspection_date") @db.Timestamptz

  // Statistics
  stats Json @default("{}") // Production, inspections, etc.

  // Relations
  owner              UserProfile             @relation("ApiaryOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members            ApiaryMembership[]
  hives              Hive[]
  locationHistory    ApiaryLocationHistory[]
  equipmentLogs      ApiaryEquipmentLog[]
  inspections        Inspection[]
  nuclei             Nucleus[]
  diseaseRecords     DiseaseRecord[]
  feedingRecommendations FeedingRecommendation[]
  feedingSchedules   FeedingSchedule[]
  harvestRecords     HarvestRecord[]
  splitOperations    SplitOperation[]
  mergeOperations    MergeOperation[]
  swarmEvents        SwarmEvent[]
  localPlants        LocalPlant[]
  forageAssessments  ForageAssessment[]
  weatherData        WeatherData[]
  weatherForecasts   WeatherForecast[]
  weatherImpacts     WeatherImpact[]
  feedingRecords     FeedingRecord[]
  alerts             Alert[]
  aiRecommendations  AIRecommendationLog[]

  @@map("apiary")
  @@index([ownerId])
  @@index([type])
  @@index([isActive])
}

model ApiaryLocationHistory {
  id        String @id @default(uuid()) @db.Uuid
  apiaryId  String @map("apiary_id") @db.Uuid

  // Location
  locationLat Decimal @map("location_lat") @db.Decimal(10, 8)
  locationLng Decimal @map("location_lng") @db.Decimal(11, 8)
  address     String?

  // Dates
  movedDate     DateTime  @map("moved_date") @db.Date
  departureDate DateTime? @map("departure_date") @db.Date

  // Reason
  reason String?
  notes  String?

  // Assessment
  forageRating       Int?     @map("forage_rating")
  productionAchieved Decimal? @map("production_achieved") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  apiary Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)

  @@map("apiary_location_history")
  @@index([apiaryId, movedDate(sort: Desc)])
}

model ApiaryEquipmentLog {
  id        String @id @default(uuid()) @db.Uuid
  apiaryId  String @map("apiary_id") @db.Uuid

  // Equipment
  equipmentType String @map("equipment_type")
  equipmentName String? @map("equipment_name")

  // Action
  action   EquipmentAction
  quantity Int             @default(1)

  // Details
  details String?
  cost    Decimal? @db.Decimal(10, 2)

  // Tracking
  performedBy String?   @map("performed_by") @db.Uuid
  performedAt DateTime  @default(now()) @map("performed_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  apiary Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)

  @@map("apiary_equipment_log")
  @@index([apiaryId, performedAt(sort: Desc)])
}

// ============================================================================
// C. HIVE MANAGEMENT (5 tables)
// ============================================================================

model Hive {
  id        String @id @default(uuid()) @db.Uuid
  apiaryId  String @map("apiary_id") @db.Uuid

  // Basic Information
  hiveNumber String @map("hive_number")
  name       String?

  // Type
  hiveType HiveType @map("hive_type")

  // Configuration
  stories       Int     @default(1)
  framesPerBox  Int     @default(10) @map("frames_per_box")
  frameSize     String? @map("frame_size") // 'deep', 'medium', 'shallow'

  // Status
  status HiveStatus @default(ACTIVE)

  // Strength
  strengthScore  Int?          @map("strength_score")
  strengthRating StrengthRating? @map("strength_rating")

  // Queen
  queenId       String?  @unique @map("queen_id") @db.Uuid
  queenAge      Int?     @map("queen_age_months")
  queenMarked   Boolean  @default(false) @map("queen_marked")
  queenColor    String?  @map("queen_color")

  // Important Dates
  installationDate    DateTime? @map("installation_date") @db.Date
  lastInspectionDate  DateTime? @map("last_inspection_date") @db.Timestamptz
  nextInspectionDue   DateTime? @map("next_inspection_due") @db.Date

  // Position in Apiary
  positionRow    Int? @map("position_row")
  positionColumn Int? @map("position_column")

  // Notes
  notes String?
  tags  String[] // ['aggressive', 'productive', 'gentle']

  // Tracking
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Statistics
  stats Json @default("{}") // Inspections, harvests, production

  // Relations
  apiary               Apiary                   @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  queen                Queen?                   @relation(fields: [queenId], references: [id], onDelete: SetNull)
  frames               HiveFrame[]
  supers               HiveSuper[]
  history              HiveHistory[]
  baladiAssessments    BaladiHiveAssessment[]
  inspections          Inspection[]
  feedingRecords       FeedingRecord[]
  feedingRecommendations FeedingRecommendation[]
  feedingSchedules     FeedingSchedule[]
  honeyHarvests        HoneyHarvest[]
  pollenHarvests       PollenHarvest[]
  royalJellyProduction RoyalJellyProduction[]
  consolidations       ConsolidationOperation[]
  swarmEvents          SwarmEvent[]             @relation("SourceHive")
  capturedSwarms       SwarmEvent[]             @relation("NewHive")
  diseaseAffected      DiseaseRecord[]
  alerts               Alert[]
  aiRecommendations    AIRecommendationLog[]
  splitAsMother        SplitOperation[]         @relation("MotherHive")
  mergeAsSurvivor      MergeOperation[]         @relation("SurvivorHive")
  mergeAsMerged        MergeOperation[]         @relation("MergedHive")

  @@unique([apiaryId, hiveNumber])
  @@map("hive")
  @@index([apiaryId])
  @@index([status])
  @@index([queenId])
}

model HiveFrame {
  id     String @id @default(uuid()) @db.Uuid
  hiveId String @map("hive_id") @db.Uuid

  // Position
  story    Int @default(1)
  position Int // 1-10

  // Type
  frameType FrameType @default(STANDARD) @map("frame_type")

  // Content Percentages (0-100)
  broodPercentage  Int        @default(0) @map("brood_percentage")
  broodType        BroodType? @map("brood_type")
  honeyPercentage  Int        @default(0) @map("honey_percentage")
  pollenPercentage Int        @default(0) @map("pollen_percentage")

  // Condition
  condition FrameCondition @default(GOOD)
  ageYears  Int            @default(0) @map("age_years")

  // Tracking
  lastUpdated DateTime @default(now()) @map("last_updated") @db.Timestamptz
  updatedBy   String?  @map("updated_by") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  hive              Hive                    @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  inspectionDetails InspectionFrameDetail[]

  @@unique([hiveId, story, position])
  @@map("hive_frame")
  @@index([hiveId])
}

model HiveSuper {
  id     String @id @default(uuid()) @db.Uuid
  hiveId String @map("hive_id") @db.Uuid

  // Information
  superNumber Int @map("super_number") // 1, 2, 3...
  frameCount  Int @default(10) @map("frame_count")

  // Settings
  queenExcluder Boolean      @default(false) @map("queen_excluder")
  queenLocation QueenLocation? @map("queen_location")

  // Dates
  addedDate   DateTime  @map("added_date") @db.Date
  removedDate DateTime? @map("removed_date") @db.Date

  // Production
  estimatedYieldKg Decimal? @map("estimated_yield_kg") @db.Decimal(10, 2)
  actualYieldKg    Decimal? @map("actual_yield_kg") @db.Decimal(10, 2)

  // Status
  status SuperStatus @default(ACTIVE)

  // Tracking
  addedBy   String?  @map("added_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  notes String?

  // Relations
  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@map("hive_super")
  @@index([hiveId])
}

model HiveHistory {
  id     String @id @default(uuid()) @db.Uuid
  hiveId String @map("hive_id") @db.Uuid

  // Event
  eventType HiveEventType @map("event_type")

  // Details
  description String
  data        Json?

  // Tracking
  performedBy String?  @map("performed_by") @db.Uuid
  performedAt DateTime @default(now()) @map("performed_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@map("hive_history")
  @@index([hiveId, performedAt(sort: Desc)])
}

model BaladiHiveAssessment {
  id     String @id @default(uuid()) @db.Uuid
  hiveId String @map("hive_id") @db.Uuid

  // Assessment
  assessmentDate DateTime @default(now()) @map("assessment_date") @db.Timestamptz

  // Activity
  flightActivity      FlightActivity @map("flight_activity")
  flightActivityScore Int            @map("flight_activity_score")

  // Building
  combBuildingRate  CombBuildingRate? @map("comb_building_rate")
  combBuildingScore Int?              @map("comb_building_score")

  // Pollen Collection
  pollenCollectionRate  PollenCollectionRate? @map("pollen_collection_rate")
  pollenCollectionScore Int?                  @map("pollen_collection_score")

  // Overall
  overallAppearance String?
  overallScore      Int?    @map("overall_score")

  // Sound
  soundAssessment String? @map("sound_assessment")

  // Weight
  estimatedWeightKg Decimal? @map("estimated_weight_kg") @db.Decimal(10, 2)

  // Weather
  weatherConditions   String?  @map("weather_conditions")
  temperatureCelsius  Decimal? @map("temperature_celsius") @db.Decimal(5, 2)

  // Notes
  notes  String?
  images String[]

  // Tracking
  assessedBy String?  @map("assessed_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  hive Hive @relation(fields: [hiveId], references: [id], onDelete: Cascade)

  @@map("baladi_hive_assessment")
  @@index([hiveId, assessmentDate(sort: Desc)])
}

// ============================================================================
// D. INSPECTIONS (4 models)
// ============================================================================

model Inspection {
  id        String @id @default(uuid()) @db.Uuid
  hiveId    String @map("hive_id") @db.Uuid
  apiaryId  String @map("apiary_id") @db.Uuid

  // Dates
  inspectionDate  DateTime @map("inspection_date") @db.Timestamptz
  durationMinutes Int?     @map("duration_minutes")

  // Type
  inspectionType InspectionType @map("inspection_type")

  // Weather
  weatherConditions  String?  @map("weather_conditions")
  temperatureCelsius Decimal? @map("temperature_celsius") @db.Decimal(5, 2)

  // Overall Assessment
  overallAssessment OverallAssessment @map("overall_assessment")
  overallScore      Int?              @map("overall_score")

  // Strength
  strengthBefore Int? @map("strength_before")
  strengthAfter  Int? @map("strength_after")

  // Queen
  queenSeen    Boolean?      @map("queen_seen")
  queenQuality QueenQuality? @map("queen_quality")
  eggsPresent  Boolean?      @map("eggs_present")
  eggsPattern  EggPattern?   @map("eggs_pattern")

  // Brood
  broodPresent         Boolean?     @map("brood_present")
  broodPattern         BroodPattern? @map("brood_pattern")
  broodFramesCount     Int?         @map("brood_frames_count")
  cappedBroodFrames    Int?         @map("capped_brood_frames")

  // Resources
  honeyFramesCount  Int?     @map("honey_frames_count")
  pollenFramesCount Int?     @map("pollen_frames_count")
  estimatedHoneyKg  Decimal? @map("estimated_honey_kg") @db.Decimal(10, 2)

  // Population
  populationEstimate PopulationEstimate? @map("population_estimate")
  framesCovered      Int?                @map("frames_covered")

  // Temperament
  temperament Temperament?

  // Diseases & Pests
  diseasesDetected Boolean @default(false) @map("diseases_detected")
  pestsDetected    Boolean @default(false) @map("pests_detected")

  // Swarm Signs
  swarmCellsPresent Boolean   @default(false) @map("swarm_cells_present")
  swarmCellsCount   Int       @default(0) @map("swarm_cells_count")
  swarmRisk         SwarmRisk? @map("swarm_risk")

  // Notes
  notes           String?
  recommendations String[]

  // Media
  images String[]
  videos String[]

  // Tracking
  inspectedBy String?  @map("inspected_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  hive        Hive                    @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  apiary      Apiary                  @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  inspector   UserProfile?            @relation(fields: [inspectedBy], references: [id])
  findings    InspectionFinding[]
  actions     InspectionAction[]
  frameDetails InspectionFrameDetail[]

  @@map("inspection")
  @@index([hiveId, inspectionDate(sort: Desc)])
  @@index([apiaryId, inspectionDate(sort: Desc)])
  @@index([diseasesDetected])
}

model InspectionFinding {
  id           String @id @default(uuid()) @db.Uuid
  inspectionId String @map("inspection_id") @db.Uuid

  // Finding
  findingType FindingType @map("finding_type")
  severity    Severity

  title       String
  description String?

  // Data
  data Json?

  // Recommended Action
  recommendedAction String?  @map("recommended_action")
  actionPriority    ActionPriority? @map("action_priority")
  actionDeadline    DateTime? @map("action_deadline") @db.Date

  // Media
  images String[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@map("inspection_finding")
  @@index([inspectionId])
}

model InspectionAction {
  id           String @id @default(uuid()) @db.Uuid
  inspectionId String @map("inspection_id") @db.Uuid

  // Action
  actionType  ActionType @map("action_type")
  description String

  // Details
  details Json?

  // Outcome
  outcome String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@map("inspection_action")
  @@index([inspectionId])
}

model InspectionFrameDetail {
  id           String @id @default(uuid()) @db.Uuid
  inspectionId String @map("inspection_id") @db.Uuid
  frameId      String @map("frame_id") @db.Uuid

  // State at inspection
  position Int

  broodPercentage       Int?       @map("brood_percentage")
  broodType             BroodType? @map("brood_type")
  broodAge              BroodAge?  @map("brood_age")

  honeyPercentage       Int? @map("honey_percentage")
  honeyCappedPercentage Int? @map("honey_capped_percentage")

  pollenPercentage Int?     @map("pollen_percentage")
  pollenColors     String[] @map("pollen_colors")

  // Notes
  condition String?
  notes     String?

  // Media
  imageUrl String? @map("image_url")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  frame      HiveFrame  @relation(fields: [frameId], references: [id], onDelete: Cascade)

  @@map("inspection_frame_detail")
  @@index([inspectionId])
}

// ============================================================================
// ENUMS
// ============================================================================

// Inspection Enums

enum InspectionType {
  ROUTINE
  DETAILED
  QUICK_CHECK
  DISEASE_CHECK
  QUEEN_CHECK
  HARVEST
  FEEDING
  TREATMENT
  OTHER

  @@map("inspection_type")
}

enum OverallAssessment {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL

  @@map("overall_assessment")
}

enum QueenQuality {
  EXCELLENT
  GOOD
  FAIR
  POOR
  ABSENT

  @@map("queen_quality")
}

enum EggPattern {
  EXCELLENT
  GOOD
  SPOTTY
  POOR
  NONE

  @@map("egg_pattern")
}

enum BroodPattern {
  EXCELLENT
  GOOD
  SPOTTY
  POOR
  NONE

  @@map("brood_pattern")
}

enum PopulationEstimate {
  VERY_STRONG
  STRONG
  MEDIUM
  WEAK
  VERY_WEAK

