model FeedingRecord {
  id        String @id @default(uuid()) @db.Uuid
  apiaryId  String @map("apiary_id") @db.Uuid
  hiveId    String @map("hive_id") @db.Uuid

  // Date
  feedingDate DateTime @map("feeding_date") @db.Timestamptz

  // Type & Location
  feedingLocation FeedingLocation @map("feeding_location")
  feedingMethod   FeedingMethod?  @map("feeding_method")

  // Content
  contentType        FeedingContentType @map("content_type")
  sugarConcentration String?            @map("sugar_concentration")
  quantityKg         Decimal?           @map("quantity_kg") @db.Decimal(10, 2)
  quantityLiters     Decimal?           @map("quantity_liters") @db.Decimal(10, 2)

  // Purpose
  purpose FeedingPurpose

  // Consumption
  consumedCompletely Boolean?  @map("consumed_completely")
  consumptionDate    DateTime? @map("consumption_date") @db.Timestamptz
  remainingAmount    Decimal?  @map("remaining_amount") @db.Decimal(10, 2)

  // Honey Quality Impact
  honeyQualityImpact     HoneyQualityImpact @default(NONE) @map("honey_quality_impact")
  daysUntilSafeHarvest   Int?               @map("days_until_safe_harvest")

  // Side Effects
  sideEffects String[]  @map("side_effects")

  // Cost
  cost Decimal? @db.Decimal(10, 2)

  // Notes
  notes String?

  // Tracking
  fedBy     String?  @map("fed_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  apiary Apiary      @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  hive   Hive        @relation(fields: [hiveId], references: [id], onDelete: Cascade)
  feeder UserProfile? @relation(fields: [fedBy], references: [id])

  @@map("feeding_record")
  @@index([apiaryId, feedingDate(sort: Desc)])
  @@index([hiveId, feedingDate(sort: Desc)])
  @@index([honeyQualityImpact])
}

model FeedingRecommendation {
  id        String @id @default(uuid()) @db.Uuid
  apiaryId  String @map("apiary_id") @db.Uuid
  hiveId    String? @map("hive_id") @db.Uuid

  // Recommendation
  recommendationDate DateTime       @default(now()) @map("recommendation_date") @db.Timestamptz
  priority           ActionPriority
  urgency            FeedingUrgency

  // Feeding Details
  recommendedType     String   @map("recommended_type")
  recommendedLocation String   @map("recommended_location")
  recommendedQuantity Decimal  @map("recommended_quantity") @db.Decimal(10, 2)
  recommendedStartDate DateTime? @map("recommended_start_date") @db.Date
  recommendedDurationDays Int? @map("recommended_duration_days")

  // Reasoning
  reasoning String
  factors   Json?

  // Expectations
  expectedBenefits String[]  @map("expected_benefits")
  expectedRisks    String[]  @map("expected_risks")
  estimatedCost    Decimal?  @map("estimated_cost") @db.Decimal(10, 2)
  expectedRoi      Decimal?  @map("expected_roi") @db.Decimal(10, 2)

  // Confidence
  confidenceScore Int @map("confidence_score")

  // Status
  status RecommendationStatus @default(PENDING)

  // Implementation
  implementedFeedingId String?   @map("implemented_feeding_id") @db.Uuid
  implementedDate      DateTime? @map("implemented_date") @db.Timestamptz

  // Evaluation
  outcomeRating Int?    @map("outcome_rating")
  outcomeNotes  String? @map("outcome_notes")

  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  expiresAt DateTime? @map("expires_at") @db.Timestamptz

  // Relations
  apiary Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  hive   Hive?  @relation(fields: [hiveId], references: [id])

  @@map("feeding_recommendation")
  @@index([apiaryId, recommendationDate(sort: Desc)])
  @@index([status])
}

model FeedingSchedule {
  id       String  @id @default(uuid()) @db.Uuid
  apiaryId String  @map("apiary_id") @db.Uuid
  hiveId   String? @map("hive_id") @db.Uuid

  // Schedule
  scheduleName String   @map("schedule_name")
  startDate    DateTime @map("start_date") @db.Date
  endDate      DateTime? @map("end_date") @db.Date

  // Frequency
  frequency  FeedingFrequency
  customDays Int[]            @map("custom_days")

  // Feeding Details
  feedingType     String  @map("feeding_type")
  feedingLocation String  @map("feeding_location")
  quantityPerFeeding Decimal @map("quantity_per_feeding") @db.Decimal(10, 2)

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Tracking
  feedingsCompleted Int       @default(0) @map("feedings_completed")
  feedingsPlanned   Int?      @map("feedings_planned")
  lastFeedingDate   DateTime? @map("last_feeding_date") @db.Timestamptz
  nextFeedingDate   DateTime? @map("next_feeding_date") @db.Date

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  apiary Apiary @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
  hive   Hive?  @relation(fields: [hiveId], references: [id])

  @@map("feeding_schedule")
  @@index([apiaryId])
  @@index([nextFeedingDate])
}

