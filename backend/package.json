{
  "name": "kingdom-of-bees-backend",
  "version": "1.0.0",
  "description": "Backend API for Kingdom of Bees",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "prisma:generate": "prisma generate --schema=../packages/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=../packages/db/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=../packages/db/prisma/schema.prisma",
    "seed:plants": "tsx prisma/seed-plants.ts",
    "test": "jest",
    "test:int": "jest -c jest.integration.config.ts --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@kingdom-of-bees/shared-types": "file:../packages/shared-types",
    "@prisma/client": "^5.22.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.6",
    "node-cron": "^4.5.0",
    "qrcode": "^1.5.4",
    "speakeasy": "^2.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.3"
  },
