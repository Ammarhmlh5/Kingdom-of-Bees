  newHivesCount Int      @map("new_hives_count")
  newHiveIds    String[] @map("new_hive_ids") @db.Uuid

  // Method
  method SplitMethod
  
  // Split Type (for walk-away, emergency, etc.)
  splitType String? @map("split_type")

  // Resource Distribution
  resourceDistribution Json @map("resource_distribution")

