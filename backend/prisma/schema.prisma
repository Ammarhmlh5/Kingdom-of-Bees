model Queen {
  id String @id @default(uuid()) @db.Uuid

  // Basic Information
  queenNumber String? @map("queen_number")
  name        String?

  // Source
  source          QueenSource
  
  // Genetics
  beeBreedId String?   @map("bee_breed_id") @db.Uuid
  beeBreed   BeeBreed? @relation(fields: [beeBreedId], references: [id])

  breederApiaryId String?     @map("breeder_apiary_id") @db.Uuid
  motherQueenId   String?     @map("mother_queen_id") @db.Uuid

  // Dates
  birthDate        DateTime? @map("birth_date") @db.Date
  introductionDate DateTime? @map("introduction_date") @db.Date
  deathDate        DateTime? @map("death_date") @db.Date

  // Marking
  marked     Boolean @default(false)
  markColor  String? @map("mark_color")
  markNumber String? @map("mark_number")

  // Quality
  qualityRating Int?           @map("quality_rating")
  eggLayingRate EggLayingRate? @map("egg_laying_rate")
  temperament   Temperament?

  // Performance
  productivityScore      Int? @map("productivity_score")
  diseaseResistanceScore Int? @map("disease_resistance_score")

  // Genetics
  geneticsData Json? @map("genetics_data")

  // Status
  status           QueenStatus @default(ACTIVE) @map("status")
  currentHiveId    String?     @map("current_hive_id") @db.Uuid
  currentNucleusId String?     @map("current_nucleus_id") @db.Uuid

  // Statistics
  offspringCount Int @default(0) @map("offspring_count")
  hivesQueened   Int @default(0) @map("hives_queened")

  // Notes
  notes String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  motherQueen    Queen?       @relation("QueenLineage", fields: [motherQueenId], references: [id])
  daughters      Queen[]      @relation("QueenLineage")
  currentHive    Hive?
  currentNucleus Nucleus?     @relation(fields: [currentNucleusId], references: [id])
  nuclei         Nucleus[]    @relation("NucleusQueen")
  breederUser    UserProfile? @relation("QueenBreeder", fields: [breederApiaryId], references: [id])

  @@index([status])
  @@index([currentHiveId])
  @@index([motherQueenId])
  @@map("queen")
}

model Nucleus {
  id       String @id @default(uuid()) @db.Uuid
  apiaryId String @map("apiary_id") @db.Uuid

  // Information
  nucleusNumber String  @map("nucleus_number")
  name          String?

  // Configuration
  frameCount Int @default(3) @map("frame_count")

  // Queen
  queenId               String?             @map("queen_id") @db.Uuid
  queenIntroductionDate DateTime?           @map("queen_introduction_date") @db.Date
  queenStatus           NucleusQueenStatus? @map("queen_status")

  // Strength
  strengthScore      Int?    @map("strength_score")
  populationEstimate String? @map("population_estimate")

  // Purpose
  purpose NucleusPurpose

  // Dates
  createdDate    DateTime  @map("created_date") @db.Date
  graduationDate DateTime? @map("graduation_date") @db.Date

  // Status
  status NucleusStatus @default(ACTIVE)

  // Notes
  notes String?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  apiary       Apiary  @relation(fields: [apiaryId], references: [id], onDelete: Cascade)
