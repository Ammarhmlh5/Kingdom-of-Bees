  operationType String   @map("operation_type")
  predictedDate DateTime @map("predicted_date") @db.Date
  confidenceScore Float?  @map("confidence_score")

  // Factors
  factors Json?

  // Result
  actualDate   DateTime? @map("actual_date") @db.Date
  accuracyDays Int?       @map("accuracy_days")

  // Status
  status      String @default("PENDING") // PENDING, MATCHED, MISSED
  isResolved  Boolean @default(false) @map("is_resolved")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  hive    Hive              @relation(fields: [hiveId], references: [id])
  matches PredictionMatch[]

  @@index([apiaryId, operationType])
  @@index([hiveId])
  @@map("operation_analysis")
}

model PredictionMatch {
  id           String   @id @default(uuid()) @db.Uuid
  analysisId   String   @map("analysis_id") @db.Uuid
  apiaryId     String   @map("apiary_id") @db.Uuid
  hiveId       String?  @map("hive_id") @db.Uuid

  // Resolving Operation
  resolvingOperationId String? @map("resolving_operation_id") @db.Uuid

  // Match Info
  predictedDate DateTime? @map("predicted_date") @db.Date
  actualDate    DateTime? @map("actual_date") @db.Date
  matchedAt     DateTime @default(now()) @map("matched_at") @db.Timestamptz

  // Accuracy
  isAccurate    Boolean? @map("is_accurate")
  accuracyDays  Int?      @map("accuracy_days")
  accuracyScore Decimal   @map("accuracy_score") @db.Decimal(5, 2)

  // Data
  predictedData     Json? @map("predicted_data")
  actualOutcomeData Json? @map("actual_outcome_data")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  analysis OperationAnalysis @relation(fields: [analysisId], references: [id])

  @@index([analysisId])
  @@index([apiaryId, matchedAt(sort: Desc)])
  @@map("prediction_match")
}

// ============================================================================
// Hive Condition (Enum - stored separately for query flexibility)
// ============================================================================

enum HiveCondition {
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
  WEAK
  CRITICAL
  UNKNOWN

  @@map("hive_condition")
}