{
  "name": "kingdom-of-bees",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "backend",
    "frontend-web",
    "admin-panel",
    "mobile-app"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:nx": "nx run-many -t build",
    "dev": "turbo run dev",
    "dev:nx": "nx run-many -t dev",
    "lint": "turbo run lint",
    "lint:nx": "nx run-many -t lint",
    "test": "turbo run test",
    "test:nx": "nx run-many -t test",
    "typecheck": "turbo run typecheck",
    "typecheck:nx": "nx run-many -t typecheck",
    "graph": "nx graph"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.9.1",
    "nx": "^23.1.0",
    "prisma": "^5.22.0",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^5.2.1"
  },
  "packageManager": "npm@10.8.2",
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
